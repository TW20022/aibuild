# --- 硬件坐标 ---
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_jdcloud_re-sp-01b=y

# --- 打印全家桶 (关键) ---
CONFIG_PACKAGE_cups=y
CONFIG_PACKAGE_cups-filters=y
CONFIG_PACKAGE_ghostscript=y
CONFIG_PACKAGE_hplip=y
# 禁用会导致冲突和庞大体积的子包
# CONFIG_PACKAGE_hplip-common is not set
# CONFIG_PACKAGE_hplip-sane is not set

# --- USB 基础驱动 (避开内核 lp0 抢占) ---
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_usbutils=y
# CONFIG_PACKAGE_kmod-usb-printer is not set

# --- 存储支持 (支持 U 盘挂载) ---
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_block-mount=y

# --- LuCI 界面与汉化 ---
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-cupsd=y
CONFIG_PACKAGE_luci-i18n-cupsd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# --- 编译优化 ---
CONFIG_USE_STRIP=y
CONFIG_STRIP_ARGS="--strip-all"
