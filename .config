# 目标硬件平台 (京东云 RE-SP-01B)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_jdcloud_re-sp-01b=y

# 核心基础包 (精简网络组件)
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_procd-ujail=y

# 硬件驱动：无线与 USB (wpad 改为 basic)
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt7615e=y
CONFIG_PACKAGE_kmod-mt7615-firmware=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-printer=y
CONFIG_PACKAGE_kmod-lp=y

# 打印机核心 (三剑客：CUPS + HPLIP + Ghostscript)
CONFIG_PACKAGE_cups=y
CONFIG_PACKAGE_libcups=y
CONFIG_PACKAGE_cups-filters=y
CONFIG_PACKAGE_hplip=y
CONFIG_PACKAGE_hplip-common=y
# 移除 hplip-sane (扫描功能) 以节省空间和 Python 依赖
CONFIG_PACKAGE_ghostscript=y

# 界面与汉化 (轻量化方案)
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-app-cupsd=y
CONFIG_PACKAGE_luci-i18n-cupsd-zh-cn=y
CONFIG_PACKAGE_luci-compat=y

# 文件系统 (移除 NTFS，保留基础)
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_usbutils=y

# 编译优化策略
CONFIG_USE_STRIP=y
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_TARGET_ROOTFS_PARTSIZE=160
